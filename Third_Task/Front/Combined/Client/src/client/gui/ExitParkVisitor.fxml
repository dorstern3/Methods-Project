<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #f9f9f9; -fx-border-color: #2d5d2d; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.gui.ExitParkVisitorController">
   <children>
      <VBox alignment="CENTER" layoutX="100.0" layoutY="40.0" spacing="20.0" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="80.0" AnchorPane.topAnchor="40.0">
         <children>
            <Label text="GoNature - Visitor Exit" textFill="#2d5d2d">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Order Number or QR Code:" textFill="#333333">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <TextField fx:id="orderIdInput" prefHeight="40.0" prefWidth="250.0" style="-fx-background-radius: 10;" />
               </children>
            </VBox>
            
            <Button fx:id="exitBtn" mnemonicParsing="false" onAction="#onExitClicked" prefHeight="50.0" prefWidth="250.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="REGISTER EXIT">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
            
            <Label fx:id="statusLabel" alignment="CENTER" prefHeight="25.0" prefWidth="400.0" text="" textAlignment="CENTER">
               <font>
                  <Font name="System Italic" size="14.0" />
               </font>
            </Label>
            
            <Button mnemonicParsing="false" onAction="#onBackClicked" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand;" text="Back to Dashboard">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>

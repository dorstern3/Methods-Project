<AnchorPane prefHeight="440.0" prefWidth="432.0" style="-fx-border-color: Green;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="client.gui.ReportsController">
   <children>
      <VBox prefHeight="440.0" prefWidth="432.0">
         <children>
            <AnchorPane prefHeight="398.0" prefWidth="432.0" style="-fx-border-color: Red;">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <children>
                  <Button layoutX="380.0" layoutY="2.0" mnemonicParsing="false" onAction="#openDashboard" text="Dashboard" />
               </children>
            </AnchorPane>
            <HBox alignment="CENTER" prefHeight="50.0" prefWidth="432.0" spacing="50.0" style="-fx-border-color: blue;">
               <children>
                  <Button mnemonicParsing="false" text="Visitors Report" onAction="#onClickVisitorsReport"/>
                  <Button mnemonicParsing="false" text="Cancling Report" onAction="#onClickCanclingReport"/>

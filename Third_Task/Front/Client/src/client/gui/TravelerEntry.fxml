<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="663.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.gui.TravelerEntryController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #ffffff; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
               <children>
                  <Label text="GoNature - Traveler Portal" textFill="#2e7d32">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label text="Manage bookings and personal profile parameters sequence window" textFill="#555555">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            
            <VBox alignment="CENTER" maxWidth="520.0" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 15 25 15 25; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="NEVER">
               <children>
                  <Label text="Enter Identification / Subscriber Number to unlock actions:" textFill="#333333">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtTravelerId" alignment="CENTER" maxWidth="300.0" prefHeight="35.0" promptText="Enter ID or Subscriber Number" style="-fx-background-radius: 6; -fx-border-color: #2e7d32; -fx-border-radius: 6; -fx-font-size: 14px; -fx-font-weight: bold;" />
               </children>
               <VBox.margin>
                  <Insets left="71.0" />
               </VBox.margin>
            </VBox>
            
            <Label fx:id="lblError" alignment="CENTER" maxWidth="520.0" textFill="RED" wrapText="true">
               <font><Font name="System Bold" size="12.0" /></font>
               <VBox.margin>
                  <Insets left="71.0" />
               </VBox.margin>
            </Label>
            
            <GridPane hgap="15.0" maxWidth="520.0" vgap="15.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <VBox.margin>
                  <Insets left="71.0" />
               </VBox.margin>
               <children>
                  
                  <Button fx:id="btnNewOrder" mnemonicParsing="false" onAction="#clickNewOrder" maxWidth="1.7976931348623157E308" prefHeight="50.0" style="-fx-background-color: #2e7d32; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Book New Visit" GridPane.columnIndex="0" GridPane.rowIndex="0">
                     <font><Font size="14.0" /></font>
                  </Button>
                  
                  <Button fx:id="btnManageOrder" mnemonicParsing="false" onAction="#clickManageOrder" maxWidth="1.7976931348623157E308" prefHeight="50.0" style="-fx-background-color: #757575; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Manage Existing Order" GridPane.columnIndex="1" GridPane.rowIndex="0">
                     <font><Font size="14.0" /></font>
                  </Button>
                  
                  <Button fx:id="btnExit" mnemonicParsing="false" onAction="#onExitParkClicked" maxWidth="1.7976931348623157E308" prefHeight="50.0" style="-fx-background-color: #757575; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Exit Park" GridPane.columnIndex="0" GridPane.rowIndex="1">
                     <font><Font size="14.0" /></font>
                  </Button>
                  
                  <Button fx:id="btnEditSubscriber" mnemonicParsing="false" onAction="#onEditSubscriberDetailsClicked" maxWidth="1.7976931348623157E308" prefHeight="50.0" style="-fx-background-color: #757575; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="View / Edit Profile Subscriber" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <font><Font size="14.0" /></font>
                  </Button>
                  
               </children>
            </GridPane>
            
            <Button fx:id="btnBack" mnemonicParsing="false" onAction="#clickBack" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #b0bec5; -fx-text-fill: #37474f; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Back">
               <VBox.margin>
                  <Insets left="71.0" top="10.0" />
               </VBox.margin>
            </Button>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
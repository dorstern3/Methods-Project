<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="663.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.gui.AlternativeDatesFormController">
   <children>
      <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="30.0">
         <children>
            
            <VBox maxWidth="520.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 4);">
               <children>
                  
                  <VBox spacing="4.0">
                     <children>
                        <Label text="Alternative Available Dates" textFill="#2e7d32">
                           <font>
                              <Font name="System Bold" size="22.0" />
                           </font>
                        </Label>
                        <Label text="The requested slot is full. Please select an alternative option:" textFill="#c62828" style="-fx-font-weight: bold;">
                           <font>
                              <Font size="12.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  
                  <TableView fx:id="tblAlternativeDates" prefHeight="260.0" prefWidth="470.0" style="-fx-background-radius: 6; -fx-border-color: #e0e0e0; -fx-border-radius: 6;">
                    <columns>
                      <TableColumn fx:id="colDate" prefWidth="235.0" text="Available Date" />
                      <TableColumn fx:id="colTime" prefWidth="235.0" text="Available Time" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  
                  <HBox alignment="CENTER" spacing="170.0">
                     <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#clickCancel" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: #757575; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Back" />
                        <Button fx:id="btnBook" mnemonicParsing="false" onAction="#clickBook" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #2e7d32; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Book Selected Date" />
                     </children>
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </HBox>
                  
               </children>
            </VBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
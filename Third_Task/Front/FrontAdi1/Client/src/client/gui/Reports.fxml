<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="492.0" prefWidth="527.0" style="-fx-border-color: Green;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.gui.ReportsController">
   <children>
      <VBox prefHeight="492.0" prefWidth="527.0">
         <children>
            <AnchorPane fx:id="reportContainer" prefHeight="398.0" prefWidth="432.0" style="-fx-border-color: Red;">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </AnchorPane>
            <HBox alignment="CENTER" prefHeight="50.0" prefWidth="432.0" spacing="50.0" style="-fx-border-color: blue;">
               <children>
                  <Button mnemonicParsing="false" onAction="#openDashboard" text="Dashboard" />
                  <Button fx:id="btnVisitorsReport" mnemonicParsing="false" onAction="#onClickVisitorsReport" text="Visitors Report" />
                  <Button fx:id="btnCancellationsReport" mnemonicParsing="false" onAction="#onClickCanclingReport" prefHeight="25.0" prefWidth="123.0" text="Cancellation Report" />
                  <Button fx:id="btnTotalVisitorsReport" mnemonicParsing="false" text="Total Visitors Report" />
                  <Button fx:id="btnOccupancyReport" mnemonicParsing="false" text="Occupancy Report" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>

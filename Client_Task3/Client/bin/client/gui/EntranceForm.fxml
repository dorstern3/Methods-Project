<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.gui.EntranceController">
   <children>
      
      <Label layoutX="40.0" layoutY="20.0" text="GoNature - Park Entrance Control" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>

      <TabPane layoutX="40.0" layoutY="60.0" prefHeight="200.0" prefWidth="520.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          
          <Tab text="Pre-booked Order">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <VBox layoutX="14.0" layoutY="20.0" spacing="10.0">
                           <children>
                              <Label text="Enter Order ID ">
                                 <font><Font size="14.0" /></font>
                              </Label>
                              <TextField fx:id="orderIdInput" prefHeight="30.0" prefWidth="250.0" promptText="e.g., 12345" />
                              <Button mnemonicParsing="false" onAction="#onCheckOrderClicked" prefHeight="30.0" prefWidth="120.0" text="Check Order" />
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          
          <Tab text="Casual Visitor">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <VBox layoutX="14.0" layoutY="15.0" spacing="10.0">
                           <children>
                              <Label text="Visitor Type:" />
                              <ComboBox fx:id="visitorTypeCombo" prefWidth="150.0" promptText="Select Type" />
                           </children>
                        </VBox>
                        <VBox layoutX="180.0" layoutY="15.0" spacing="10.0">
                           <children>
                              <Label text="Amount of Visitors:" />
                              <TextField fx:id="casualAmountInput" prefWidth="100.0" promptText="e.g., 2" />
                           </children>
                        </VBox>
                        <VBox layoutX="300.0" layoutY="15.0" spacing="10.0">
                           <children>
                              <Label text="ID (If Subscriber):" />
                              <TextField fx:id="casualIdInput" prefWidth="150.0" promptText="Optional" />
                           </children>
                        </VBox>
                        <Button layoutX="14.0" layoutY="90.0" mnemonicParsing="false" onAction="#onCheckCasualClicked" prefHeight="30.0" prefWidth="200.0" text="Check Capacity &amp; Price" />
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
        </tabs>
      </TabPane>

      <Label fx:id="messageLabel" layoutX="40.0" layoutY="270.0" prefWidth="520.0" wrapText="true">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <VBox fx:id="invoiceSection" layoutX="40.0" layoutY="300.0" prefWidth="520.0" spacing="15.0" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-border-radius: 5; -fx-background-color: #f8f9fa;">
         <children>
            <Label text="Billing &amp; Invoice Summary" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            
            <Label fx:id="finalPriceLabel" text="Total to pay: 0.00 NIS" textFill="#27ae60">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            
            <Button mnemonicParsing="false" onAction="#onConfirmPaymentClicked" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Register Payment &amp; Entry" />
         </children>
      </VBox>

      <Button layoutX="40.0" layoutY="490.0" mnemonicParsing="false" onAction="#onBackButtonClicked" prefHeight="30.0" prefWidth="150.0" text="Back to Dashboard" />
      
   </children>
</AnchorPane>

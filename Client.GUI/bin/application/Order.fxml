<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@OrderStyles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.OrderLogic">
   <children>
      <VBox fx:id="Main_box" layoutX="10.0" layoutY="7.0" spacing="5.0" styleClass="Main_box" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            
            <HBox alignment="CENTER" spacing="15.0" VBox.vgrow="NEVER">
               <children>
                  <Label text="Server IP:" />
                  <TextField fx:id="serverIpField" prefWidth="120.0" text="localhost" />
                  <Label text="Port:" />
                  <TextField fx:id="serverPortField" prefWidth="80.0" text="5555" />
                  <Button mnemonicParsing="false" onAction="#onConnect" text="Connect" />
               </children>
               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER" pickOnBounds="false" spacing="50.0" styleClass="Update_box" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="UpdateButton" mnemonicParsing="false" onAction="#onUpdate" text="Update" />
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                     <children>
                        <Label text="Order Number:" />
                        <Label text="Number of visitor" />
                        <Label text="Order date" />
                     </children>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                     <children>
                        <TextField fx:id="OrderNumber" maxWidth="200.0" minWidth="100.0" prefWidth="150.0" />
                        <TextField fx:id="NumOfVisitors" prefHeight="12.0" prefWidth="109.0" />
                        <DatePicker fx:id="NewDate" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" top="20.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
            <HBox alignment="CENTER" spacing="20.0" styleClass="Show_data_box" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="Show_data" mnemonicParsing="false" onAction="#onShowTable" text="Show data" />
                  <TableView minWidth="600.0" prefHeight="200.0" prefWidth="600.0">
                    <columns>
                      <TableColumn prefWidth="100.0" text="Order Number" />
                      <TableColumn prefWidth="75.0" text="Date" />
                        <TableColumn prefWidth="75.0" text="Visitors" />
                        <TableColumn prefWidth="120.0" text="Confirmation Code" />
                        <TableColumn prefWidth="100.0" text="Subscriber ID" />
                        <TableColumn prefWidth="120.0" text="Date of Order" />
                    </columns>
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="20.0" top="20.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>